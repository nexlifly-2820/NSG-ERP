+/* ==============================================
+   RESPONSIVE TABLES & GRIDS (Deep Analysis Fixes)
+   ============================================== */
+
+/* Pure CSS Responsive Tables - Make tables scrollable without wrappers */
+table.ceo-erp-table,
+table.data-table,
+table.ts-table,
+table.att-log-table,
+table.lv-table,
+table.trackerTable,
+table.prodTable,
+.premiumTable {
+  display: block !important;
+  width: 100% !important;
+  max-width: 100% !important;
+  overflow-x: auto !important;
+  -webkit-overflow-scrolling: touch; /* Smooth scrolling for iOS */
+  border-collapse: collapse;
+  white-space: nowrap; /* Prevents columns from squishing */
+}
+
+/* Ensure table inside wrapper maintains min-width and doesn't squish */
+table.ceo-erp-table tbody,
+table.data-table tbody,
+table.ts-table tbody,
+table.att-log-table tbody,
+table.lv-table tbody,
+table.trackerTable tbody,
+table.prodTable tbody,
+.premiumTable tbody,
+table.ceo-erp-table thead,
+table.data-table thead,
+table.ts-table thead,
+table.att-log-table thead,
+table.lv-table thead,
+table.trackerTable thead,
+table.prodTable thead,
+.premiumTable thead {
+  display: table !important;
+  width: 100% !important;
+  min-width: 800px; /* Force minimum width to trigger scroll on small screens */
+}
+
+/* For tight columns like Action, Date, Status */
+.whitespace-nowrap {
+  white-space: nowrap !important;
+}
+
+/* Responsive Grid for Side-by-side Panels (e.g. Settings Page) */
+@media (max-width: 1024px) {
+  .responsive-panel-grid {
+    grid-template-columns: 1fr !important; /* Stack vertically on small screens */
+  }
+}
