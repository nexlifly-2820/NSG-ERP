+  *[style*="width: 500px"],
+  *[style*="width: 560px"],
+  *[style*="width: 600px"],
+  *[style*="width: 800px"],
+  *[style*="width: 900px"] {
+    width: 100% !important;
+    max-width: 100% !important;
+    box-sizing: border-box !important;
+  }
+
+  /* Modals padding and width bounds */
+  div[style*="position: fixed"] > div.card,
+  div[style*="position: fixed"] > div[style*="background"] {
+    max-width: calc(100vw - 32px) !important;
+    margin: 0 16px !important;
+    max-height: 85vh !important;
+    overflow-y: auto !important;
+  }
+
+  /* Stack flex rows in forms (except action buttons) */
+    grid-template-columns: 1fr;
+    gap: 16px;
+  }
+}
+
+/* Global Component Container Centering for Ultra-wide screens */
+.component-container {
+  max-width: 1600px;
+  margin: 0 auto;
+}
